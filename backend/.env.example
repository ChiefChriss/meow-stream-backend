# Required for iOS app auth (Bearer token)
APP_SECRET=change-me-to-a-random-secret

# Public URL of this backend (used for proxy stream URLs; defaults to localhost in dev)
BACKEND_PUBLIC_URL=http://127.0.0.1:3000

# Optional: Upstash Redis for stream URL caching
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
